ANTHROPIC_API_KEY=

FALKORDB_HOST=localhost
FALKORDB_PORT=6379
BUBBLE_MODEL=claude-sonnet-4-6

BUBBLE_EMBED_DIM=768
BUBBLE_EMBED_ENDPOINT=http://localhost:8997/v1/embeddings

BUBBLE_RERANK_ENABLED=false
BUBBLE_RERANK_ENDPOINT=http://localhost:8998/rerank


BUBBLE_ENABLE_NLI=false
BUBBLE_NLI_ENDPOINT=http://localhost:8999/predict

# ── bubble tuning constants ──────────────────────────────────────────────────
#
# BUBBLE_EPISODIC_THRESHOLD  Intensity floor for episodic storage. Segments at or
#                            above this score are written to the JSONL archive and
#                            stored as Episodes (not SegmentNodes). Lower → more
#                            memories become episodic. Higher → only peak-intensity
#                            moments are treated as episodes.
BUBBLE_EPISODIC_THRESHOLD=0.6

# BUBBLE_PROMOTE_THRESHOLD   t_promo_score threshold for promoting a cluster to
#                            Layer 1 (belief). Lower → more clusters promote,
#                            noisier beliefs. Higher → only very dense/intense
#                            clusters reach Layer 1.
#                            diagnose output: shows t_promo_score per cluster vs this value.
BUBBLE_PROMOTE_THRESHOLD=0.2

# BUBBLE_CLUSTER_MIN_SIZE    HDBSCAN minimum number of segments to form a cluster.
#                            Lower → more (potentially spurious) clusters. Raise if
#                            you see false beliefs forming from unrelated segments.
#                            diagnose output: shows how many noise points exist at
#                            current setting.
BUBBLE_CLUSTER_MIN_SIZE=3

# BUBBLE_CHAIN_MAX_DISTANCE  Cosine distance ceiling for chain assignment. New
#                            Episodes farther than this from the nearest existing
#                            Episode skip the LLM check and start their own chain.
#                            Lower → stricter (more isolated chains). Higher → more
#                            aggressive chain grouping.
#                            diagnose output: shows pairwise Episode distance matrix.
BUBBLE_CHAIN_MAX_DISTANCE=0.4

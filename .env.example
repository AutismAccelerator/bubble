ANTHROPIC_API_KEY=

FALKORDB_HOST=localhost
FALKORDB_PORT=6379
BUBBLE_MODEL=claude-sonnet-4-6
BUBBLE_EMBED_MODEL=jinaai/jina-embeddings-v5-text-nano-clustering
BUBBLE_EMBED_DIM=768
BUBBLE_EMBED_ENDPOINT=http://localhost:8997

BUBBLE_RERANK_ENABLED=false
BUBBLE_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
BUBBLE_RERANK_ENDPOINT=http://localhost:8998

# ── bubble tuning constants ──────────────────────────────────────────────────
#
# BUBBLE_THETA          t_promo_score promotion threshold. Lower → more clusters
#                       promote, noisier beliefs. Higher → only very dense/intense
#                       clusters reach Layer 1.
#                       diagnose output: shows t_promo_score per cluster vs this value.
BUBBLE_THETA=0.2

# BUBBLE_MIN_CLUSTER_SIZE  HDBSCAN minimum cluster size. Lower → more (potentially
#                          spurious) clusters. Raise if you see false beliefs forming
#                          from unrelated segments.
#                          diagnose output: shows how many noise points exist at
#                          current setting.
BUBBLE_MIN_CLUSTER_SIZE=3


# BUBBLE_T_DISTANCE    Chain assignment similarity floor: cosine *distance* ceiling.
#                        New Episodes with distance > t_similarity to the closest
#                        existing node skip the LLM check and form their own chain.
#                        Lower → stricter (more isolated chains). Higher → more
#                        aggressive chain grouping.
#                        diagnose output: shows pairwise Episode distance matrix.
BUBBLE_T_DISTANCE=0.4
